{
  "name": "spark-demo-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "prebuild:android": "expo prebuild --platform android",
    "build:apk": "expo prebuild --platform android && cd android && ./gradlew assembleRelease && cp app/build/outputs/apk/release/app-release.apk ../../docs/spark-demo.apk"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "expo": "~52.0.46",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-linking": "~7.0.5",
    "expo-localization": "~16.0.1",
    "expo-router": "~4.0.20",
    "expo-status-bar": "~2.0.1",
    "i18next": "^24.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^15.4.1",
    "react-native": "0.76.9",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/react": "~18.3.20",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "~5.8.2"
  },
  "private": true
}
